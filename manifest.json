{
  "manifest_version": 3,
  "name": "YouTube Shorts Blocker",
  "description": "Remove Shorts entry points from the regular YouTube interface without blocking direct Shorts URLs.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
